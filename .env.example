OPENAI_API_KEY=
HF_TOKEN=
MODAL_API_KEY=
PUSHOVER_USER=
PUSHOVER_TOKEN=

# Dataset defaults
# Structured datasets are app-ready and should be used for vectorstore/RF/DNN pipelines.
DEALSIGHT_INTELLIGENCE_STRUCTURED_DATASET_SOURCE=abhinavvathadi/items_lite
DEALSIGHT_INTELLIGENCE_DATASET_PREFIX=lite
DEALSIGHT_INTELLIGENCE_STRUCTURED_TRAIN_PATH=artifacts/datasets/train_lite.pkl
DEALSIGHT_INTELLIGENCE_STRUCTURED_VALIDATION_PATH=artifacts/datasets/validation_lite.pkl
DEALSIGHT_INTELLIGENCE_STRUCTURED_TEST_PATH=artifacts/datasets/test_lite.pkl

# Prompt datasets are only for prompt/completion fine-tuning or prompt eval scripts.
DEALSIGHT_INTELLIGENCE_PROMPT_DATASET_SOURCE=abhinavvathadi/items_prompts_lite

# Raw datasets are preserved as supported sources, but are not default app-ready datasets.
DEALSIGHT_INTELLIGENCE_RAW_DATASET_SOURCE=abhinavvathadi/items_raw_lite

# Optional Modal specialist model. Override these to point at your own fine-tuned adapter.
DEALSIGHT_INTELLIGENCE_MODAL_HF_SECRET=huggingface-secret
DEALSIGHT_INTELLIGENCE_MODAL_GPU=T4
DEALSIGHT_INTELLIGENCE_MODAL_MIN_CONTAINERS=0
DEALSIGHT_INTELLIGENCE_BASE_MODEL=meta-llama/Meta-Llama-3.1-8B
DEALSIGHT_INTELLIGENCE_FINETUNE_HF_USER=ed-donner
DEALSIGHT_INTELLIGENCE_FINETUNE_PROJECT_NAME=pricer
DEALSIGHT_INTELLIGENCE_FINETUNE_RUN_NAME=2024-09-13_13.04.39
DEALSIGHT_INTELLIGENCE_FINETUNE_REVISION=e8d637df551603dc86cd7a1598a8f44af4d7ae36

# Optional providers and switches
DEEPSEEK_API_KEY=
DEALSIGHT_INTELLIGENCE_DRY_RUN=true
DEALSIGHT_INTELLIGENCE_ENABLE_MODAL=true
DEALSIGHT_INTELLIGENCE_ENABLE_DNN=true
DEALSIGHT_INTELLIGENCE_DO_PUSH=false
DEALSIGHT_INTELLIGENCE_FEED_LIMIT=10
DEALSIGHT_INTELLIGENCE_MAX_DEALS=5
DEALSIGHT_INTELLIGENCE_DISCOUNT_THRESHOLD=50

# Optional experiment tracking
WANDB_API_KEY=
WANDB_PROJECT=dealsight-intelligence
# W&B is disabled by default in scripts unless you pass --wandb.
WANDB_MODE=offline
